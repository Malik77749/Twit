{
  "rules": {
    "users": {
      ".indexOn": ["phone"],
      "$uid": {
        ".read": true,
        ".write": "auth.uid === $uid",
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50"
        },
        "bio": {
          ".validate": "newData.isString() && newData.val().length <= 160"
        },
        "profilePicture": {
          ".validate": "newData.isString()"
        },
        "isAdmin": {
          ".write": false
        },
        "followers": {
          ".validate": "newData.isNumber()"
        },
        "following": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": true
        }
      }
    },

    "posts": {
      "$postId": {
        ".read": true,
        ".write": "auth != null",
        "content": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "userId": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "timestamp": {
          ".validate": "newData.isString()"
        },
        "likes": {
          ".validate": "newData.isNumber()"
        },
        "retweets": {
          ".validate": "newData.isNumber()"
        },
        "views": {
          ".validate": "newData.isNumber()"
        },
        "imageUrl": {
          ".validate": "newData.isString()"
        },
        "videoUrl": {
          ".validate": "newData.isString()"
        },
        "edited": {
          ".validate": "newData.isBoolean()"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "comments": {
      "$postId": {
        "$commentId": {
          ".read": true,
          ".write": "auth != null",
          "content": {
            ".validate": "newData.isString() && newData.val().length <= 500"
          },
          "userId": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "timestamp": {
            ".validate": "newData.isString()"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },

    "likes": {
      "$postId": {
        "$uid": {
          ".read": true,
          ".write": "auth.uid === $uid"
        }
      }
    },

    "bookmarks": {
      "$uid": {
        "$postId": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid"
        }
      }
    },

    "followers": {
      "$targetUid": {
        "$followerUid": {
          ".read": true,
          ".write": "auth.uid === $followerUid"
        }
      }
    },

    "retweets": {
      "$retweetId": {
        ".read": true,
        ".write": "auth != null",
        "userId": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "originalPostId": {
          ".validate": "newData.isString()"
        },
        "timestamp": {
          ".validate": "newData.isString()"
        }
      }
    },

    "notifications": {
      "$uid": {
        "$notifId": {
          ".read": "auth.uid === $uid",
          ".write": "auth != null"
        }
      }
    },

    "reports": {
      "$reportId": {
        ".read": false,
        ".write": "auth != null"
      }
    },

    "bans": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": false
      }
    },

    "rateLimits": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },

    "deletedPosts": {
      "$postId": {
        ".read": false,
        ".write": "auth != null"
      }
    }
  }
}
