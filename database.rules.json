{
  "rules": {
    "users": {
      ".indexOn": ["phone", "handle"],
      "$uid": {
        ".read": true,
        ".write": "auth.uid === $uid",
        "name": {
          ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 50"
        },
        "bio": {
          ".validate": "newData.isString() && newData.val().length <= 160"
        },
        "profilePicture": {
          ".validate": "newData.isString()"
        },
        "isAdmin": {
          ".write": false
        },
        "followers": {
          ".validate": "newData.isNumber()"
        },
        "following": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": true
        }
      }
    },

    "posts": {
      ".indexOn": ["timestamp"],
      "$postId": {
        ".read": true,
        ".write": "auth != null",
        "content": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "userId": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "timestamp": {
          ".validate": "newData.isString()"
        },
        "likes": {
          ".validate": "newData.isNumber()"
        },
        "retweets": {
          ".validate": "newData.isNumber()"
        },
        "views": {
          ".validate": "newData.isNumber()"
        },
        "imageUrl": {
          ".validate": "newData.isString()"
        },
        "videoUrl": {
          ".validate": "newData.isString()"
        },
        "edited": {
          ".validate": "newData.isBoolean()"
        },
        "$other": {
          ".validate": false
        }
      }
    },

    "comments": {
      "$postId": {
        ".indexOn": ["timestamp"],
        "$commentId": {
          ".read": true,
          ".write": "auth != null",
          "content": {
            ".validate": "newData.isString() && newData.val().length <= 500"
          },
          "userId": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "timestamp": {
            ".validate": "newData.isString()"
          },
          "$other": {
            ".validate": false
          }
        }
      }
    },

    "likes": {
      "$postId": {
        "$uid": {
          ".read": true,
          ".write": "auth.uid === $uid"
        }
      }
    },

    "bookmarks": {
      "$uid": {
        "$postId": {
          ".read": "auth.uid === $uid",
          ".write": "auth.uid === $uid"
        }
      }
    },

    "followers": {
      "$targetUid": {
        "$followerUid": {
          ".read": true,
          ".write": "auth.uid === $followerUid"
        }
      }
    },

    "retweets": {
      "$retweetId": {
        ".read": true,
        ".write": "auth != null",
        "userId": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "originalPostId": {
          ".validate": "newData.isString()"
        },
        "timestamp": {
          ".validate": "newData.isString()"
        }
      }
    },

    "notifications": {
      "$uid": {
        "$notifId": {
          ".read": "auth.uid === $uid",
          ".write": "auth != null"
        }
      }
    },

    "reports": {
      "$reportId": {
        ".read": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
        ".write": "auth != null"
      }
    },

    "bans": {
      "$uid": {
        ".read": "auth.uid === $uid || root.child('users').child(auth.uid).child('isAdmin').val() === true",
        ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true"
      }
    },

    "auditLog": {
      "$logId": {
        ".read": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
        ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true"
      }
    },

    "siteSettings": {
      ".read": "root.child('users').child(auth.uid).child('isAdmin').val() === true",
      ".write": "root.child('users').child(auth.uid).child('isAdmin').val() === true"
    },

    "rateLimits": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },

    "deletedPosts": {
      "$postId": {
        ".read": false,
        ".write": "auth != null"
      }
    },

    "hashtags": {
      "$tag": {
        ".read": true,
        ".write": "auth != null",
        "$postId": {
          ".validate": "newData.isBoolean()"
        }
      }
    },

    "fcmTokens": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },

    "conversations": {
      "$convId": {
        ".read": "data.child('participants').hasChild(auth.uid)",
        ".write": "auth != null",
        "participants": {
          ".validate": true
        },
        "isGroup": {
          ".validate": "newData.isBoolean()"
        },
        "groupName": {
          ".validate": "newData.isString() && newData.val().length <= 50"
        },
        "$other": {
          ".validate": true
        }
      }
    },

    "messages": {
      "$convId": {
        ".read": "root.child('conversations').child($convId).child('participants').hasChild(auth.uid)",
        ".write": "root.child('conversations').child($convId).child('participants').hasChild(auth.uid)",
        "$msgId": {
          "senderId": {
            ".validate": "newData.isString() && newData.val() === auth.uid"
          },
          "text": {
            ".validate": "newData.isString() && newData.val().length <= 1000"
          },
          "$other": {
            ".validate": true
          }
        }
      }
    }
  }
}
